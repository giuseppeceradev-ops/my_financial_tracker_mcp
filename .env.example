# ── Google API (OAuth2) ─────────────────────────────────────────────────────────
# Download credentials.json from Google Cloud Console after enabling the Google API.
# See credentials/README.md for step-by-step setup.
GOOGLE_CREDENTIALS_PATH=./credentials/credentials.json
GOOGLE_TOKEN_PERSISTENCY_PATH=./credentials/token.json
GOOGLE_APPLICATION_CREDENTIALS=./credentials/vision-key.json


# ── MCP Server ────────────────────────────────────────────────────────────────
# Port the server listens on (default: 8001)
MCP_PORT=8001

# MCP spec OAuth 2.0 authentication.
# Set to a secret value to enable auth. This value is the CONSENT PAGE PASSWORD —
# when a new MCP client tries to connect, your browser shows a page asking you to
# type it before approving the connection. Once approved, the client stores a
# refresh token and reconnects silently. When enabled, FastMCP exposes:
#   /.well-known/oauth-authorization-server  OAuth discovery
#   /register                                dynamic client registration
#   /authorize → /oauth/consent              browser consent page
#   /token                                   code ↔ access+refresh tokens
# MCP clients (Claude Code, VS Code, MCP Inspector) discover and complete the
# flow automatically. Leave empty to run without auth (local development).
MCP_AUTH_TOKEN=

# Path to persist MCP OAuth state (registered clients + refresh tokens) across restarts.
# Default: credentials/oauth_state.json — delete this file to force all clients to re-authenticate.
MCP_OAUTH_STATE_PATH=./credentials/oauth_state.json

# Elicitation failure mode for destructive tools (send_email, reply_to_email).
# Default (unset): fail-closed — raise an error if the client does not support elicitation.
# Set to any non-empty value: fail-open — proceed without confirmation (not recommended for production).
MCP_ELICITATION_FAIL_OPEN=1


GEMINI_API_KEY=
GEMINI_MODEL = "gemini-3-flash-preview"

DRIVE_INVOICES_FOLDER = "your google drive folder id"
DRIVE_RECEIPTS_FOLDER = "your google drive folder id"

PUBLIC_BASE_URL = "localhost:8001"

DB_FOLDER = "./my_financial_tracker_mcp/database"
DB_NAME = "my_fin_trace.db"

# Default folder where invoices/receipts are kept for processing
FILES_PATH = "./my_financial_tracker_mcp/files"